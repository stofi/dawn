{{ 'section-image-gallery.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="image-gallery color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul
        class="image-gallery__grid image-gallery__grid--{{ section.settings.columns_desktop }}"
        role="list"
      >
        {%- liquid
          assign images_to_show = section.settings.images_to_show
          if images_to_show == 0
            assign images_to_show = section.blocks.size
          endif
        -%}
        {%- for block in section.blocks -%}
          {%- if forloop.index > images_to_show -%}
            {%- continue -%}
          {%- endif -%}
          <li
            class="image-gallery__item image-gallery__item--{{ section.settings.image_ratio }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              style="animation-delay: {{ forloop.index | times: 100 }}ms;"
            {% endif %}
          >
            {%- if block.settings.image != blank -%}
              <button
                type="button"
                aria-label="{{ block.settings.caption | default: block.settings.image.alt | default: 'View image' | escape }} - {{ 'products.modal.label' | t }}"
                data-lightbox-index="{{ forloop.index0 }}"
                data-lightbox-target="#ImageGalleryLightbox-{{ section.id }}"
              >
                {%- liquid
                  assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                  if section.settings.image_ratio == 'adapt'
                    assign sizes = '(min-width: 750px) calc((100vw - 10rem) / ' | append: section.settings.columns_desktop | append: '), calc(50vw - 3rem)'
                  else
                    assign sizes = '(min-width: 750px) calc((100vw - 10rem) / ' | append: section.settings.columns_desktop | append: '), calc(50vw - 3rem)'
                  endif
                -%}
                {{
                  block.settings.image
                  | image_url: width: 1500
                  | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500'
                }}
              </button>
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            {%- if block.settings.caption != blank -%}
              <p class="image-gallery__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>

      {%- comment -%} Lightbox {%- endcomment -%}
      <image-gallery-lightbox id="ImageGalleryLightbox-{{ section.id }}" class="image-gallery-lightbox">
        <div class="image-gallery-lightbox__overlay"></div>
        <div class="image-gallery-lightbox__dialog" role="dialog" aria-modal="true" aria-label="Image gallery" tabindex="-1">
          <button type="button" class="image-gallery-lightbox__close" aria-label="{{ 'accessibility.close' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>

          <button type="button" class="image-gallery-lightbox__nav image-gallery-lightbox__nav--prev" aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>

          <div class="image-gallery-lightbox__content">
            {%- for block in section.blocks -%}
              {%- if block.settings.image != blank -%}
                <div class="image-gallery-lightbox__image-wrapper" data-index="{{ forloop.index0 }}">
                  {{
                    block.settings.image
                    | image_url: width: 3840
                    | image_tag: loading: 'lazy', sizes: '100vw', widths: '750, 1100, 1500, 1780, 2000, 3000, 3840'
                  }}
                  {%- if block.settings.caption != blank -%}
                    <span class="image-gallery-lightbox__caption">{{ block.settings.caption }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <button type="button" class="image-gallery-lightbox__nav image-gallery-lightbox__nav--next" aria-label="{{ 'sections.slideshow.next_slideshow' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 6 15 12 9 18"></polyline>
            </svg>
          </button>
        </div>
      </image-gallery-lightbox>
    {%- endif -%}
  </div>
</div>

<script src="{{ 'image-gallery-lightbox.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Image gallery",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Gallery"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3",
      "label": "Desktop columns"
    },
    {
      "type": "range",
      "id": "images_to_show",
      "min": 0,
      "max": 20,
      "step": 1,
      "label": "Images to show in grid",
      "info": "0 shows all. The rest are only visible in the lightbox.",
      "default": 0
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.slideshow.settings.slide_height.options__1.label" },
        { "value": "square", "label": "Square" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "square",
      "label": "Image ratio"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
